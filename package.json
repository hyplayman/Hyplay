{
  "name": "windows-11-emulator",
  "version": "1.0.0",
  "description": "Una aplicación web que emula perfectamente Windows 11 con interfaz moderna y funcionalidad completa",
  "main": "index.html",
  "scripts": {
    "start": "python -m http.server 8000 || python3 -m http.server 8000",
    "serve": "npx http-server . -p 8000 -o",
    "dev": "npx live-server --port=8000 --open=/",
    "build": "echo 'No build process needed for static files'",
    "deploy": "echo 'Ready for deployment - upload all files to web server'"
  },
  "keywords": [
    "windows-11",
    "emulator",
    "desktop",
    "web-app",
    "javascript",
    "html5",
    "css3",
    "ui",
    "interface"
  ],
  "author": "Windows 11 Emulator",
  "license": "MIT",
  "devDependencies": {
    "http-server": "^14.1.1",
    "live-server": "^1.2.2"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/windows-11-emulator.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/windows-11-emulator/issues"
  },
  "homepage": "https://github.com/yourusername/windows-11-emulator#readme"
}